// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model GameSession {
  id           String         @id @default(uuid()) @db.Uuid
  name         String
  formation    String         @default("4-3-3")
  createdAt    DateTime       @default(now())
  squadRating  Int?
  status       String         @default("in_progress") // "in_progress" | "completed"
  userId       String         // Supabase User ID
  players      CareerPlayer[]

  @@map("game_sessions")
}

model CareerPlayer {
  id                String      @id @default(uuid()) @db.Uuid
  gameSessionId     String      @db.Uuid
  gameSession       GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)
  slotIndex         Int         // 0 to 10 representing position in formation

  // Identity
  name              String
  nationality       String
  position          String      // GK, LB, CB, RB, CDM, CM, CAM, LW, ST, RW
  height            Int
  preferredFoot     String      // "Right" | "Left" | "Both"

  // Career Arc
  debutAge          Int
  retireAge         Int
  careerLengthYears Int

  // Stats & Rarity
  debutOvr          Int
  peakOvr           Int
  cardRarity        String      // bronze, silver, gold, rare_gold, epic, legendary
  currentContinentalCup String @default("none") // "UCL" | "UEL" | "UECL" | "Libertadores" | "AFC_CL" | "CONCACAF_CC" | "CAF_CL" | "none"

  // Timelines & Logs (Stored as JSON)
  statsTimeline     Json        // Array of StatsSnapshot: { age, ovr, pac, sho, pas, dri, def, phy, ... }
  clubStints        Json        // Array of ClubStint: { clubId, clubName, leagueId, leagueName, startAge, endAge, yearsAtClub, ovrAtJoining, ovrAtLeaving }
  events            Json        // Array of CareerEvent: { type, label, age, clubId, nationality }
  hiddenStats       Json        // HiddenStats: { personality, professionalism, luckRating } (Server-only)
  achievements      Json?       // Cumulative trophies object: { ballonDor, trophies[], seasonAwards[] }
  seasonHistory     Json        @default("{}") // Record<age, SeasonRecord> — persisted for resume
  isRetired         Boolean     @default(false)

  @@unique([gameSessionId, slotIndex])
  @@map("career_players")
}

model League {
  id        String   @id // e.g., "ENG1", "ESP1"
  name      String
  country   String
  tier      Int      // 1 or 2
  prestige  Int      // 1 to 5 stars
  clubs     Club[]

  @@map("leagues")
}

model NationalTeam {
  id            String @id // e.g., "england", "france"
  name          String // Tên hiển thị tiếng Việt: "Anh", "Pháp"
  nationality   String @unique // Key tiếng Anh khớp với CareerPlayer.nationality
  confederation String // "UEFA" | "CONMEBOL" | "AFC" | "CAF" | "CONCACAF"
  tier          Int    // 1 = Tier 1, 2 = Tier 2, 3 = Tier 3

  @@map("national_teams")
}

model Club {
  id                     String   @id // e.g., "real_madrid", "man_city"
  name                   String
  leagueId               String
  league                 League   @relation(fields: [leagueId], references: [id])
  prestige               Int      // 1 to 5 stars
  leagueTitlesCount      Int      @default(0)
  domesticCupsCount      Int      @default(0)
  continentalTitlesCount Int      @default(0)
  continentalType        String   @default("none") // "UCL" | "UEL" | "UECL" | "Libertadores" | "AFC_CL" | "none"

  @@map("clubs")
}
